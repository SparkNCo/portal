{
  "type": "json_schema",
  "json_schema": {
    "name": "project_proposal",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "features_description": {
          "type": "string"
        },
        "proposal_features": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "feature_name": {
                "type": "string"
              },
              "feature_description": {
                "type": "string"
              },
              "feature_timeline": {
                "type": "string"
              },

              "feature_priority": {
                "type": "string"
              }
            },
            "required": [
              "feature_name",
              "feature_description",
              "feature_timeline",
              "feature_priority"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": ["features_description", "proposal_features"],
      "additionalProperties": false
    }
  }
}
